# Copy to .env and fill in before running ./deploy.sh
#   cp env.example .env

# --- GCP project ---
GCP_PROJECT_ID=your-gcp-project
GCP_REGION=europe-west1

# Create project if it does not exist (requires billing account permission)
CREATE_GCP_PROJECT=false
# GCP_PROJECT_NAME="Mill Cloud Run"   # quote if spaces
# GCP_BILLING_ACCOUNT_ID=XXXXXX-XXXXXX-XXXXXX
# Optional parent (only one): numeric ID, or resource prefix form
# GCP_FOLDER_ID=123456789             # or folders/123456789
# GCP_ORGANIZATION_ID=123456789       # or organizations/123456789

# --- GCS bucket (Skymill config YAML) ---
# Globally unique bucket name; created on deploy when set
GCS_BUCKET_NAME=your-gcp-project-mill-config
GCS_BUCKET_LOCATION=europe-west1

# Upload local files listed in config/gcs-sync.conf before Cloud Run deploy
GCS_SYNC_ENABLED=false
GCS_SYNC_CONFIG=config/gcs-sync.conf
# GCS_SYNC_DELETE_EXTRA=false   # rsync: delete GCS objects not present locally

# Cloud Run service
CLOUD_RUN_SERVICE_NAME=mill-service

# Docker Hub image (published by release CI as qpointz/mill-service-<edition>:<version>)
MILL_DOCKER_IMAGE=docker.io/qpointz/mill-service-complete:latest

# Spring profiles. For GCS-backed Skymill config:
#   SPRING_PROFILES_ACTIVE=skymill-gcs,postgres,secure
#   CUSTOM_APPLICATION_YML=config/application-cloudrun-gcs.yml
#   GCS_SYNC_ENABLED=true
SPRING_PROFILES_ACTIVE=skymill,postgres,secure

# PostgreSQL (required for profile postgres)
MILL_DB_URL=jdbc:postgresql://YOUR_HOST:5432/mill?sslmode=require
MILL_DB_USERNAME=mill
MILL_DB_PASSWORD=CHANGE_ME

# Optional: Cloud SQL
# CLOUD_SQL_CONNECTION_NAME=project:region:instance
# MILL_DB_URL=jdbc:postgresql:///mill?cloudSqlInstance=project:region:instance&socketFactory=com.google.cloud.sql.postgres.SocketFactory

# Optional GCS project override (defaults to GCP_PROJECT_ID when bucket is set)
# MILL_CLOUD_GCP_GCS_PROJECT_ID=your-gcp-project

# Optional OpenAI (profile ai) — omit from shell env if unused
# OPENAI_API_KEY=

# Custom Spring config (Secret Manager → file mount, not under /config — see deploy.sh)
# CUSTOM_APPLICATION_YML=config/application-cloudrun-gcs.yml

# Container sizing
CLOUD_RUN_CPU=1
CLOUD_RUN_MEMORY=2Gi
CLOUD_RUN_MIN_INSTANCES=0
CLOUD_RUN_MAX_INSTANCES=3
CLOUD_RUN_CONCURRENCY=80
CLOUD_RUN_PORT=8080
CLOUD_RUN_ALLOW_UNAUTHENTICATED=true

# CLOUD_RUN_SERVICE_ACCOUNT=mill-cloud-run@your-gcp-project.iam.gserviceaccount.com

# --- Labels & destroy (see ./destroy.sh) ---
# Resources created by deploy.sh are labeled:
#   mill-managed-by=google-cloud-run
#   mill-deploy-stack=<MILL_DEPLOY_STACK_ID>
# MILL_DEPLOY_STACK_ID=mill-service   # default: CLOUD_RUN_SERVICE_NAME
# DESTROY_SCOPE=service               # destroy.sh: service | tagged | project
# DESTROY_YES=false                   # set true or use -y to skip prompts
