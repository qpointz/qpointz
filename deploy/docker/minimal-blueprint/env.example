# Copy to .env (gitignored). Loaded by run.sh / run.ps1 before CLI flags.
#
#   cp env.example .env

# Container image (override: export MILL_IMAGE=... or ./run.sh --image ...)
MILL_IMAGE=qpointz/mill-service-minimal:latest
# MILL_IMAGE=qpointz/mill-service-minimal:0.8.0rc3

# MILL_DATA_DIR=./data
MILL_HOST_PORT=8080
MILL_CONTAINER_NAME=mill-minimal-blueprint

