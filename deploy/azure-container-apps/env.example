# Copy to .env and fill in before running ./deploy.sh
#   cp env.example .env

# Azure subscription (optional if `az account show` is already correct)
# AZURE_SUBSCRIPTION_ID=

# Resource naming (must be globally unique where noted)
AZURE_LOCATION=westeurope
AZURE_RESOURCE_GROUP=rg-mill-aca
AZURE_ACA_ENV_NAME=mill-aca-env
AZURE_CONTAINER_APP_NAME=mill-service
AZURE_ACR_NAME=millacr          # lowercase alphanumeric, 5–50 chars, globally unique

# Container image
MILL_IMAGE_TAG=latest
MILL_APP_EDITION=complete        # Gradle edition: complete includes cloud-azure

# Spring profiles (comma-separated). Typical Azure Skymill deploy:
#   skymill-azure,postgres,secure
# Add oauth only after configuring Entra ID / Authentik redirect URIs for the ACA URL.
SPRING_PROFILES_ACTIVE=skymill-azure,postgres,secure

# PostgreSQL (required for metadata JPA + Flyway with profile postgres)
# Use an existing Flexible Server or set DEPLOY_POSTGRES=true (slow, dev-sized SKU).
MILL_DB_URL=jdbc:postgresql://YOUR_SERVER.postgres.database.azure.com:5432/mill?sslmode=require
MILL_DB_USERNAME=milladmin
MILL_DB_PASSWORD=CHANGE_ME

# Optional: create a small Azure Database for PostgreSQL Flexible Server during deploy
DEPLOY_POSTGRES=false
POSTGRES_SERVER_NAME=mill-pg-aca   # globally unique host prefix
POSTGRES_ADMIN_USER=milladmin
POSTGRES_ADMIN_PASSWORD=CHANGE_ME
POSTGRES_DB_NAME=mill

# Azure Blob config loading (overrides any value in packaged application.yml)
MILL_CLOUD_AZURE_ADLS_CONNECTION_STRING=

# Alternatively use managed identity (leave connection string empty, set endpoint, enable MI below)
# MILL_CLOUD_AZURE_ADLS_BLOB_SERVICE_ENDPOINT=https://YOUR_ACCOUNT.blob.core.windows.net
# ACA_MANAGED_IDENTITY=true

# Container sizing
ACA_CPU=1.0
ACA_MEMORY=2.0Gi
ACA_MIN_REPLICAS=1
ACA_MAX_REPLICAS=1

# Ingress
ACA_INGRESS_EXTERNAL=true
ACA_TARGET_PORT=8080
