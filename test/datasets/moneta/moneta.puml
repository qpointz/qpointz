@startuml
skinparam linetype ortho
left to right direction
entity "clients" {
	client_id: i
	first_name: O
	last_name: O
	email: O
	phone: O
	created_at: O
	country: O
	city: O
	address: O
	segment: O
}
entity "accounts" {
	account_id: i
	client_id: i
	account_type: O
	balance: f
	opened_at: O
}
entity "transactions" {
	transaction_id: i
	account_id: i
	transaction_type: O
	amount: f
	transaction_date: O
	description: O
}
entity "loans" {
	loan_id: i
	client_id: i
	amount: f
	interest_rate: f
	start_date: O
	end_date: O
	status: O
}
entity "loan_payments" {
	payment_id: i
	loan_id: i
	payment_date: O
	amount: f
}
entity "stock_portfolios" {
	portfolio_id: i
	client_id: i
	portfolio_name: O
	created_at: O
}
entity "stocks" {
	stock_id: i
	ticker: O
	company_name: O
	sector: O
	exchange: O
}
entity "stock_holdings" {
	holding_id: i
	portfolio_id: i
	stock_id: i
	shares: i
	average_price: f
}
entity "trade_orders" {
	order_id: i
	portfolio_id: i
	stock_id: i
	order_type: O
	order_date: O
	shares: i
	limit_price: f
	status: O
}
"clients"  ||..|{  "accounts"
"accounts"  ||..|{  "transactions"
"clients"  ||..|{  "loans"
"loans"  ||..|{  "loan_payments"
"clients"  ||..|{  "stock_portfolios"
"stock_portfolios"  ||..|{  "stock_holdings"
"stocks"  ||..|{  "stock_holdings"
"stock_portfolios"  ||..|{  "trade_orders"
"stocks"  ||..|{  "trade_orders"
@enduml
