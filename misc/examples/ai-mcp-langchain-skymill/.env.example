# OpenAI (required for skymill_agent.py)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Mill MCP HTTP endpoint (Streamable HTTP / SSE)
MILL_MCP_URL=http://localhost:8080/services/mcp

# Auth when mill.security.enable=true (pick one style)
# MILL_MCP_TOKEN=your-bearer-token
MILL_MCP_BASIC_USER=usr1
MILL_MCP_BASIC_PASSWORD=password
